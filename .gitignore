# Local .terraform directories
**/.terraform/*

# Terraform lock file (uncomment if you want to ignore it)
# .terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files (but NOT terraform.tfvars)
*.auto.tfvars
*.auto.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan

# SSH keys
*.pem
*.key

# OS files
.DS_Store
Thumbs.db
